# Nimbus environment variables.
# Copy this file to .env and fill in your values. Never commit .env to git.

# ── Recommended minimal setup: OpenAI LLM + local speech (no other keys) ──
# OpenAI API key (required for the default LLM provider)
#   Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Provider selection
LLM_PROVIDER=openai
STT_PROVIDER=faster-whisper   # local, offline, no key
TTS_PROVIDER=kokoro           # local, offline, no key

# OpenAI vision model (gpt-4o is a solid, widely-available default)
OPENAI_MODEL_VISION=gpt-4o

# ── Optional cloud upgrades (faster, but need their own keys) ──
# AssemblyAI streaming speech-to-text (set STT_PROVIDER=assemblyai to use)
#   Sign up at https://www.assemblyai.com/dashboard/signup
# ASSEMBLYAI_API_KEY=
#
# Cartesia streaming text-to-speech (set TTS_PROVIDER=cartesia to use)
#   Sign up at https://play.cartesia.ai/sign-in
# CARTESIA_API_KEY=

# ── Other optional overrides (defaults live in config.py) ──
# HOTKEY=ctrl+alt+space
# ANNOTATION_MODE=on            # enable draw-on-screen teaching mode
# MEMORY_DIR=                   # defaults to ~/.nimbus/memory/
# KOKORO_VOICE=af_heart         # local TTS voice
